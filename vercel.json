{
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "https://mockyo.onrender.com/sitemap.xml"
    },
    {
      "source": "/api/:path*",
      "destination": "https://mockyo.onrender.com/api/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
